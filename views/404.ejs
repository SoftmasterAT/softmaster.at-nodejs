<%- include('partials/header') %>

<main>
    <!-- Hero Section -->
    <section class="hero relative overflow-hidden min-h-[70vh] flex items-center justify-center py-20">
        <canvas id="hero-canvas" class="absolute inset-0 z-0"></canvas>
        <div class="container relative z-10 px-5 text-center max-w-4xl mx-auto pt-20">
            <h1 class="animate-on-scroll text-5xl md:text-7xl font-black tracking-tighter mb-6 bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-emerald-400" style="line-height: 7.5rem">
                Page Not Found
            </h1>
            <h2 class="animate-on-scroll text-2xl md:text-3xl font-semibold mb-8 opacity-90">
                <%= lang.home_intro %>
            </h2>
            <p class="animate-on-scroll text-lg md:text-xl text-gray-400 leading-relaxed text-justify max-w-2xl mx-auto mb-10">
                <%= lang.home_text %>
            </p>
            <strong class="animate-on-scroll block text-sky-500 tracking-widest uppercase text-sm font-bold">
                <%= lang.home_slogan %>
            </strong>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
