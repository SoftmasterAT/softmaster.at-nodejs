<%- include('partials/header') %>

<main>
    <!-- Hero Section -->
    <section class="hero relative overflow-hidden min-h-[70vh] flex items-center justify-center py-20">
        <canvas id="hero-canvas" class="absolute inset-0 z-0"></canvas>
        <div class="container relative z-10 px-5 text-center max-w-4xl mx-auto pt-20">
            <h1 class="animate-on-scroll text-5xl md:text-7xl font-black tracking-tighter mb-3 bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-emerald-400">
                <%= lang.home_h1 %>
            </h1>
            <div class="animate-on-scroll flex justify-center py-3">
                <div class="inline-flex items-center gap-6 px-6 py-3 bg-[var(--card-bg)]/20 border border-green-500/20 rounded-full backdrop-blur-xl shadow-[0_0_20px_rgba(34,197,94,0.1)]">
                    <span class="flex h-3 w-3 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </span>
                    <div class="flex gap-4 text-[10px] md:text-xs font-mono text-green-400/80 uppercase tracking-widest">
                        <span>Uptime: <b id="pulse-uptime"><%= serverPulse.uptime %></b>s</span>
                        <span class="hidden md:inline">|</span>
                        <span>Heap: <b id="live-memory"><%= serverPulse.memory %></b>MB</span>
                        <span class="hidden md:inline">|</span>
                        <span>Env: <b><%= serverPulse.platform %></b></span>
                    </div>
                </div>
            </div>
            <script>
                (function() {
                    // Startwert vom Server übernehmen
                    let currentUptime = parseInt("<%= serverPulse.uptime %>");
                    const uptimeDisplay = document.getElementById('pulse-uptime');
                    const memoryDisplay = document.getElementById('live-memory');

                    async function updatePulse() {
                        try {
                            const response = await fetch('/api/pulse');
                            const data = await response.json();
                            
                            // Update the DOM with real server data
                            if(uptimeDisplay) uptimeDisplay.textContent = data.uptime.toLocaleString();
                            if(memoryDisplay) memoryDisplay.textContent = data.memory;
                        } catch (err) {
                            console.error("Pulse sync failed");
                        }
                    }
                    setInterval(updatePulse, 1000);
                    })();
            </script>
            <h2 class="animate-on-scroll text-2xl md:text-3xl font-semibold mb-8 opacity-90">
                <%= lang.home_intro %>
            </h2>
            <p class="animate-on-scroll text-lg md:text-xl text-gray-400 leading-relaxed text-justify max-w-2xl mx-auto mb-10">
                <%= lang.home_text %>
            </p>
            <strong class="animate-on-scroll block text-sky-500 tracking-widest uppercase text-sm font-bold">
                <%= lang.home_slogan %>
            </strong>
            <div class="flex flex-col items-center text-center space-y-10 py-6">
                <!-- Section Title -->
                <strong class="animate-on-scroll block text-sky-500 tracking-[0.2em] uppercase text-xs font-black opacity-80">
                    <%= lang.tech %>
                </strong>

                <!-- Centered Icon Grid -->
                <div class="flex justify-center gap-8 md:gap-12 max-w-5xl mx-auto px-4">
                    <% tech.forEach(t => { %>
                        <div class="group relative flex flex-col items-center">
                            <!-- Icon Wrapper -->
                            <div class="relative w-12 h-12 md:w-14 md:h-14 flex items-center justify-center rounded-full transition-all duration-500 transform-gpu hover:scale-110 hover:shadow-[0_0_25px_<%= t.color %>]"
                                style="background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 70%);">
                                
                                <!-- The WebP Image -->
                                <img src="<%= t.src %>" 
                                    alt="<%= lang[t.alt] %>" 
                                    title="<%= lang[t.title] %>" 
                                    class="w-12 h-12 md:w-14 md:h-14 object-contain filter brightness-75 group-hover:brightness-100 transition-all duration-500">
                                
                                <!-- Glowing Border Overlay (Hidden until hover) -->
                                <!-- <div class="absolute inset-0 rounded-full border-2 border-transparent group-hover:border-sky-400/50 transition-colors duration-500"></div> -->
                            </div>
                            
                            <!-- Optional: Small label under icon (can be removed if only icons desired) -->
                            <span class="mt-1 text-[10px] uppercase tracking-tighter text-[<?= $t['color'] ?>] opacity-0 group-hover:opacity-100 transition-opacity duration-300 mb-3">
                                <%= t.name %>
                            </span>
                        </div>
                    <% }) %>
                </div>
                <!-- Foundation Stack (HTML, CSS, SVG) -->
                <div class="flex justify-center gap-5">
                    <% foundation_tech.forEach(f => { %>
                        <div class="group relative flex flex-col items-center">
                            <div class="relative w-12 h-12 flex items-center justify-center rounded-full transition-all duration-500 transform-gpu hover:scale-110 hover:shadow-[0_0_25px_<%= f.color %>]"
                                style="background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 70%);">
                                <img src="<%= f.src %>" 
                                    alt="<%= lang[f.alt] %>" 
                                    title="<%= lang[f.title] %>" 
                                    class="w-8 h-8 object-contain filter brightness-75 group-hover:brightness-100 transition-all duration-500">
                            </div>
                        </div>
                    <% }) %>
                </div>
                <!-- The Switch Button -->
                <div class="pt-4 animate-on-scroll">
                    <a href="https://www.softmaster.at" 
                    class="group relative inline-flex items-center gap-4 px-10 py-4 bg-[var(--btn-primary)]/50 border border-sky-600/20 text-[var(--text-main)] font-bold rounded-2xl transition-all hover:border-sky-500 hover:shadow-[0_0_30px_rgba(14,165,233,0.2)]">
                        <span class="text-sm uppercase tracking-widest"><%= lang.switch_to_php %></span>
                        <span class="text-xl group-hover:translate-x-2 transition-transform">→</span>
                        <img src="icons/php.webp" alt="lang.tech_php_alt" title="lang.tech_php_title" class="w-8 h-8 object-contain filter brightness-75 group-hover:brightness-100 transition-all duration-500">
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Highlights Slider -->
    <section class="py-12 md:py-20">
        <div class="container mx-auto px-5">
            <div class="relative overflow-hidden rounded-[2.5rem] bg-[var(--text-dim)]/5 border border-[#94a3b8]/10 backdrop-blur-2xl shadow-[0_5px_20px_rgba(0,0,0,0.3)] h-[650px] md:h-[550px]" id="main-hero-highlights">
                
                <% highlights.forEach((item, index) => { %>
                    <div class="h-slide <%= (index === 0) ? 'active' : '' %> absolute inset-0 flex flex-col md:flex-row items-center">
                        
                        <!-- LEFT: Image -->
                        <div class="w-full md:w-1/2 h-1/2 md:h-full overflow-hidden relative">
                            <img src="/<%= item.image %>" 
                                 class="w-full h-full object-cover h-img" 
                                 alt="<%= item.title %>">
                            <div class="absolute inset-0 bg-gradient-to-r from-[#2B4F9C]/20 to-transparent"></div>
                        </div>

                        <!-- RIGHT: Content -->
                        <div class="w-full md:w-1/2 p-8 md:p-16 space-y-6 bg-gradient-to-br from-white/[0.02] to-transparent h-full flex flex-col justify-center">
                            <div class="space-y-4 overflow-hidden">
                                <h3 class="text-4xl md:text-5xl font-black tracking-tight text-[var(--text-main)] leading-tight h-title">
                                    <%= item.title %>
                                </h3>
                                <div class="w-20 h-1 bg-sky-500 rounded-full origin-left h-bar"></div>
                            </div>
                            
                            <p class="text-[var(--text-dim)]-300 text-lg md:text-xl leading-relaxed h-desc">
                                <%= lang[item.desc_key] %>
                            </p>

                            <div class="pt-4 h-btn">
                                <a href="<%= item.link %>" target="_blank" class="inline-flex items-center gap-3 px-10 py-5 bg-[var(--btn-primary)] hover:bg-sky-600 text-[var(--text-main)] hover:shadow-[#38bdf8]/20 font-extrabold rounded-2xl transition-all hover:scale-105 shadow-xl">
                                    <span><%= lang[item.hgl_btn_key] %></span>
                                    <span class="text-2xl">→</span>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>

                <!-- Navigation Dots -->
                <div class="absolute bottom-10 right-10 flex items-center gap-6 z-30">
                    <div class="flex space-x-3">
                        <% highlights.forEach((item, index) => { %>
                            <button data-index="<%= index %>" onclick="moveHighlight(this.dataset.index)" class="h-dot w-3 h-3 rounded-full bg-[#28869d]/20 transition-all duration-500 hover:bg-white/50 <%= (index === 0) ? 'active' : '' %>"
                                    aria-label="Go to slide <%= index + 1 %>">
                            </button>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="container mx-auto py-24 px-5" id="services">
        <h2 class="animate-on-scroll text-4xl font-bold mb-16 text-center italic"><%= lang.services_title %></h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <% services.forEach(s => { %>
                <div class="animate-on-scroll group relative p-6 rounded-2xl bg-white/5 border border-[<%= s.bg_color %>]/20 hover:border-[<%= s.bg_color %>]/50 transition-all duration-500 cursor-pointer hover:-translate-y-2 flex flex-col items-center text-center" 
                     style="box-shadow: 0 10px 30px var(--shadow);"
                     onclick="location.href='/services#<%= s.id %>'">
                    
                    <div class="mb-6 w-20 h-20 rounded-2xl text-[<%= s.text_color %>] transition-transform duration-500 transform-gpu group-hover:scale-110 group-hover:bg-[<%= s.bg_color %>]/10 flex items-center justify-center">
                        <!-- Hier laden wir das Icon einfach als <img> aus dem public Ordner -->
                        <%- getSvg(s.img) %>
                    </div>

                    <h3 class="text-xl font-bold mb-4" style="--text-color: <%= s.text_color %>; color: var(--text-color);"><%= lang[s.name_key] %></h3>
                    <p class="text-gray-400 leading-relaxed"><%= lang[s.desc_key] %></p>
                    
                    <div class="absolute -inset-px rounded-3xl bg-gradient-to-br from-[<%= s.bg_color %>]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity blur-lg -z-10"></div>
                </div>
            <% }) %>
        </div>
    </section>

    <!-- Projects Section -->
    <section class="container mx-auto py-24 px-5" id="projects">
        <h2 class="animate-on-scroll text-4xl font-bold mb-16 text-center italic">
            <%= lang.projects_title %>
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <% projects.forEach(p => { %>
                <div class="group relative h-[400px] rounded-[2.5rem] border border-[<%= p.text_color %>]/20 overflow-hidden cursor-pointer shadow-2xl animate-on-scroll transition-all duration-700 hover:scale-[1.02]"  style="box-shadow: 0 10px 30px var(--shadow);" onclick="location.href='/projects#<%= p.id %>'">
                    
                    <!-- 1. Hintergrundbild mit Zoom-Effekt -->
                    <div class="absolute inset-0 z-0 flex items-center justify-center bg-[var(--card-bg)]/20 transition-transform duration-1000 group-hover:scale-110">
                        <img src="<%= p.img%>" 
                            class="h-full w-auto object-contain grayscale-[40%] group-hover:grayscale-0" 
                            loading="lazy" 
                            alt="<%= lang[p.img_alt] %>">
                    </div>

                    <!-- 2. Dynamisches Overlay (Reveal-Effekt) -->
                    <div class="absolute inset-0 z-10 bg-gradient-to-t from-[var(--card-bg)] via-[var(--card-bg)]/40 to-transparent opacity-50 transition-opacity duration-500 group-hover:opacity-80"></div>
                    
                    <!-- 3. Projekt-Farbe Akzent (schleicht sich von unten rein) -->
                    <div class="absolute inset-0 z-15 opacity-0 group-hover:opacity-40 transition-all duration-700 bg-gradient-to-br" 
                        style="--gradient-color:<%= p.text_color %>; background-image: linear-gradient(to bottom right, var(--gradient-color), transparent);"></div>

                    <!-- 4. Content (Text wandert beim Hover) -->
                    <div class="absolute inset-0 z-20 p-10 flex flex-col justify-end translate-y-4 transition-transform duration-500 group-hover:translate-y-0">
                        <span class="text-xs uppercase tracking-[0.3em] mb-2 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100 shadow-2xl" style="--text-color: <%= p.text_color %>; color: var(--text-color);">
                            <%= lang.ft_project %>
                        </span>
                        <h3 class="text-3xl font-black text-[var(--text-main)] mb-3 tracking-tight">
                            <%= p.name %>
                        </h3>
                        <p class="text-[var(--text-dim)]-300 text-lg max-w-md opacity-0 group-hover:opacity-100 transition-all duration-500 delay-200 line-clamp-2">
                            <%= lang[p.title_key] %>
                        </p>
                        
                        <!-- Ein kleiner "Arrow" Indikator -->
                        <div class="mt-6 flex items-center gap-2 text-[var(--text-dim)] font-bold opacity-0 group-hover:opacity-100 transition-all duration-700 delay-300">
                            <span><%= lang.view_details %></span>
                            <span class="transition-transform group-hover:translate-x-2">→</span>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
